# Ativa uso do LLM no seletor de sinais.
# Para rodar sem LLM, deixe 0.
PAPER_LLM_ENABLED=0

# Sobe o servidor local Qwen. Deixe 0 se nao quiser usar LLM.
# Se quiser habilitar LLM pelo dashboard depois, coloque 1 e reinicie.
PAPER_LLM_SERVER_ENABLED=0

# Modo do modelo local: fast (0.5B), balanced (1.5B), strong (Qwen3 4B)
# Em maquina com 8GB de RAM, comece com fast. Use balanced se houver folga.
PAPER_LLM_MODE=fast

# Endpoint OpenAI-compatível do servidor local Qwen
PAPER_LLM_URL=http://127.0.0.1:8080/v1/chat/completions

# Opcional: trocar portas
LLM_PORT=8080
DASHBOARD_PORT=8090
DASHBOARD_HOST=127.0.0.1

# Opcional: exigir token para acessar dashboard/API.
# Se definido, acesse http://127.0.0.1:8090/?token=SEU_TOKEN
DASHBOARD_TOKEN=

# Loop operacional. O runtime pode ajustar dinamicamente via logs/loop_seconds.txt.
PAPER_LOOP_SECONDS=90
PAPER_STRATEGY_MODE=btc_5m_momentum,endgame_last_minute,smart_money,event_countdown

# Política de execução configurável também pelo dashboard.
PAPER_MIN_NET_EDGE=0.035
PAPER_TAKER_FEE_ESTIMATE=0.001
PAPER_SLIPPAGE_ESTIMATE=0.01
PAPER_SMART_MONEY_MAX_SPREAD=0.03
PAPER_SMART_MONEY_MIN_LIQUIDITY=15000
PAPER_SMART_MONEY_MIN_VOL24H=50000
PAPER_EVENT_COUNTDOWN_MAX_SPREAD=0.06
PAPER_EVENT_COUNTDOWN_MIN_LIQUIDITY_EXEC=15000
PAPER_EVENT_COUNTDOWN_MIN_VOL24H_EXEC=25000
PAPER_BTC_MAX_ENTRY_PRICE_EXEC=0.82
PAPER_BTC_MIN_LIQUIDITY_EXEC=1000
PAPER_ENDGAME_MAX_ENTRY_PRICE_EXEC=0.95
PAPER_ENDGAME_MIN_LIQUIDITY_EXEC=1500
PAPER_SHADOW_STRATEGIES=arbitrage,value,mean_reversion,volume_spike

# Fallback DNS estático para Polymarket. Use apenas se DNS local falhar.
PAPER_POLYMARKET_STATIC_DNS=0
PAPER_POLYMARKET_STATIC_IP=104.18.34.205

# Backup local do wallet antes de cada ciclo settlement.py.
PAPER_WALLET_BACKUP_ENABLED=1
PAPER_WALLET_BACKUP_RETENTION=48

# Learning store append-only para todos os sinais/decisoes e outcomes posteriores.
PAPER_LEARNING_STORE_ENABLED=1
PAPER_LEARNING_OUTCOME_HORIZON_MINUTES=30
PAPER_LEARNING_PENDING_MAX=5000
PAPER_LEARNING_PENDING_MAX_AGE_HOURS=72

# OSINT determinístico com Google News (sem depender do modelo)
PAPER_OSINT_GOOGLE_NEWS_ENABLED=0
PAPER_OSINT_GOOGLE_NEWS_WINDOW_HOURS=24
PAPER_OSINT_GOOGLE_NEWS_MAX_ARTICLES=8
PAPER_OSINT_GOOGLE_NEWS_BONUS_CAP=0.03
