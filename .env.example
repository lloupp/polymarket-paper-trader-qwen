# Ativa uso do LLM no seletor de sinais
PAPER_LLM_ENABLED=1

# Modo do modelo local: fast (0.5B) ou balanced (1.5B)
PAPER_LLM_MODE=fast

# Endpoint OpenAI-compatível do servidor local Qwen
PAPER_LLM_URL=http://127.0.0.1:8080/v1/chat/completions

# Opcional: trocar portas
LLM_PORT=8080
DASHBOARD_PORT=8090

# Token para endpoints de controle remoto do dashboard
CONTROL_TOKEN=troque-isto
